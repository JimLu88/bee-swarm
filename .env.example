# Backend
CORS_ALLOW_ORIGINS=http://localhost:3000

# Phase 2: LLM + RAG toggles
LLM_PROVIDER=simulated
RAG_BACKEND=simulated
# Options:
# - simulated: built-in placeholder chunks
# - qdrant: Qdrant vector DB (Docker) via QDRANT_URL
# - local: SQLite FTS5 (no Docker) stored per mode_id under backend/data/
LITELLM_BASE_URL=
LITELLM_DEFAULT_MODEL=gpt-4o-mini
LITELLM_FALLBACK_MODELS=gpt-4o-mini,gpt-4.1-mini
LITELLM_MAX_RETRIES=2
LITELLM_RETRY_BASE_MS=600
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
# Qdrant 向量：留空则使用可复现的 hash 向量（64 维）。若填写且存在任一 LLM 供应商 API Key，则走 LiteLLM 文本嵌入（OpenAI 默认 1536 维）。
# 切换 hash ↔ 真实嵌入时，请删除 Qdrant 中对应 collection 或换新的 mode_id。
LITELLM_EMBEDDING_MODEL=
# 可选：覆盖向量维度（需与嵌入模型输出一致；一般不必设置）
# EMBEDDING_VECTOR_DIM=

# LLM providers (Phase 2+)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
DOUBAO_API_KEY=

# Search (Phase 3) — benchmark + xlab 视野层外搜；Tavily 优先，无结果时 Exa
# 设为 0 / false 可关闭外搜（仍走本地/向量 RAG）
BENCHMARK_WEB_SEARCH=true
TAVILY_API_KEY=
EXA_API_KEY=

# Phase 3 optional: whitelist-only subprocess (POST /api/sandbox/exec)，默认关闭
# HSEMAS_EXEC_ALLOWLIST 为逗号分隔的可执行文件 stem（如 pytest,ruff）；禁止 shell、powershell、curl、npx 等高危入口
HSEMAS_SANDBOX_EXEC_ENABLED=false
HSEMAS_EXEC_ALLOWLIST=
# 留空则用 backend 根目录；可为相对 backend 的子路径（不得跳出 backend）
HSEMAS_EXEC_CWD=
HSEMAS_EXEC_TIMEOUT_SEC=120
HSEMAS_EXEC_MAX_ARGS=40
